   <string notr="true">QMainWindow { background: #f4f6f8; }
QWidget { font-family: "Segoe UI"; font-size: 10pt; color: #20242a; }
QLabel#applicationTitle { font-size: 22pt; font-weight: 650; color: #17212b; }
